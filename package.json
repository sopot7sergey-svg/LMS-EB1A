{
  "name": "aipas",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && npm run dev",
    "dev:all": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:migrate": "cd apps/api && npm run db:migrate",
    "db:migrate:deploy": "cd apps/api && npm run db:migrate:deploy",
    "db:seed": "cd apps/api && npm run db:seed",
    "db:backup": "bash apps/api/scripts/backup-before-deploy.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "playwright": "^1.58.2",
    "puppeteer-core": "^24.39.0",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "jsdom": "^28.1.0",
    "node-fetch": "^3.3.2",
    "puppeteer": "^24.39.0"
  }
}
