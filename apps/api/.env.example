DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aipas?schema=public"
JWT_SECRET="your-secret-key-change-in-production"
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4-turbo-preview"
# Advisor Chat uses GPT-5.4 for smarter, grounded guidance (falls back to OPENAI_MODEL if unset)
OPENAI_ADVISOR_MODEL="gpt-5.4"
FRONTEND_URL="http://localhost:3000"
PORT=3001

# Billing (provider-agnostic: stripe | none)
BILLING_PROVIDER=none
BILLING_SUCCESS_URL="http://localhost:3000/account/billing?success=1"
BILLING_CANCEL_URL="http://localhost:3000/account/plans"

# Stripe (when BILLING_PROVIDER=stripe)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_ULTRA_MONTHLY=
STRIPE_PRICE_ULTRA_ANNUAL=
