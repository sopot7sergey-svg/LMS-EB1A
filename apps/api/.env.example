DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aipas?schema=public"
JWT_SECRET="your-secret-key-change-in-production"
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4-turbo-preview"
# Advisor Chat uses GPT-5.4 for smarter, grounded guidance (falls back to OPENAI_MODEL if unset)
OPENAI_ADVISOR_MODEL="gpt-5.4"
FRONTEND_URL="http://localhost:3000"
PORT=3001
